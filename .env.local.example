# Copy to `.env.local` for local development (never commit `.env.local`).
#
# --- Next.js → FastAPI proxy ---
# Leave BACKEND_URL unset so the App Router proxy targets http://127.0.0.1:8000
# (see app/api/backend/[...path]/route.ts). Only set BACKEND_URL on production hosts.
# BACKEND_URL=

# --- Browser / SSR (optional) ---
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- FastAPI (loaded from repo root via backend/main.py) ---
# Chat & explanations — get a key from Google AI Studio
# GEMINI_API_KEY=

# Omit DATABASE_URL to use SQLite at backend/sugarfree.db
# DATABASE_URL=

# Comma-separated origins for CORS (defaults include localhost:3000)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
